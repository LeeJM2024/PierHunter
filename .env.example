# ========= Core service URLs =========
DATABASE_URL=postgresql+psycopg2://scanner:scanner@postgres:5432/scannerdb
REDIS_URL=redis://redis:6379/0
CELERY_BROKER_URL=redis://redis:6379/0
CELERY_RESULT_BACKEND=redis://redis:6379/0

# ========= Runtime storage =========
DATA_DIR=/app/data
STORAGE_DIR=/app/storage
UPLOAD_DIR=/app/storage/uploads
REPORT_DIR=/app/storage/reports
LOG_DIR=/app/storage/logs
# Docker 推荐放到 storage 下；如果要兼容旧路径可改为 /app/data/phunter_soot_cache
PHUNTER_CACHE_DIR=/app/data/phunter_soot_cache
PICKLE_CACHE_DIR=/app/data/lib_pickles_cache
APK_PICKLE_CACHE_DIR=/app/data/apk_pickles_cache
SKELETON_PICKLE_CACHE_DIR=/app/data/lib_pickles_skeleton
BUCKET_PICKLE_CACHE_DIR=/app/data/lib_pickles_buckets
OUTPUT_DIR=/app/outputs
RAW_DIR=/app/outputs/raw

# ========= Scanner toolchain =========
PYTHON_BIN=python3
JAVA_BIN=java
ANDROID_JAR_PATH=/app/PHunter/android-31/android.jar
PHUNTER_JAR_PATH=/app/PHunter/PHunter.jar

# ========= Optional scanner tuning =========
MAX_PHUNTER_CONCURRENT=3
DEFAULT_PHUNTER_THREADS=8
DEFAULT_LIBHUNTER_TIMEOUT=1200
HEARTBEAT_TIMEOUT=60
LIBHUNTER_HEARTBEAT_TIMEOUT=600
WORKER_CPUS=11
LIBHUNTER_PROCESSES=11
LH_LIB_THRESHOLD=0.85

# ========= Optional intelligence agent API =========
# 不填或 INTELLIGENCE_ENABLED=false 时，系统会继续使用本地占位智能体。
INTELLIGENCE_ENABLED=false
INTELLIGENCE_PROVIDER=custom-agent
# chat_completions 或 responses。Codex 配置里的 wire_api="responses" 时填 responses。
INTELLIGENCE_API_TYPE=chat_completions
# 可填 base URL 或完整 endpoint，例如：
# https://api.openai.com/v1
# https://api.openai.com/v1/chat/completions
INTELLIGENCE_API_URL=
INTELLIGENCE_API_KEY=
INTELLIGENCE_MODEL=acchunter-agent
INTELLIGENCE_API_TIMEOUT=60
INTELLIGENCE_INCLUDE_RAW_RESPONSE=false

# ========= Postgres service bootstrap (used by compose postgres service) =========
POSTGRES_DB=scannerdb
POSTGRES_USER=scanner
POSTGRES_PASSWORD=scanner
